# ─── MOD ───
# Varsayilan: sim (GERCEK ISLEM YOK). Simulasyon 500 birim sermaye ile calisir,
# otomatik al-sat yapar. Gercek Binance islemi acmak icin "binance" yap + key ver.
EXECUTOR_MODE=sim

# Veri kaynagi: Binance (public REST, anahtarsiz) -> CoinGecko -> sentetik fallback.
# Binance bolge engelli olsa bile simulasyon calismaya devam eder.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=false
BINANCE_PROXY=
BINANCE_API_URL=

# Simülasyon başlangıç sermayesi (500 TL / 500 birim)
SIM_STARTING_CAPITAL=500

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

CHECK_INTERVAL=15
POSITION_SIZE_USD=500
RISK_PER_TRADE=2
STOP_LOSS_PCT=3
MAX_CONSECUTIVE_LOSSES=3
RR_RATIO=2

# ─── Scalping / Day Trading (M10–M30) ayarlari ───
# Indikatorlerin beslenecegi kisa vadeli periyotlar (virgulle ayrilir)
SCALP_TIMEFRAMES=10m,30m
# SL/TP icin ATR kat sayilari (kisa vade => dar)
SCALP_SL_ATR_MULT=1.0
SCALP_TP_ATR_MULT=1.8
# ATR asiri buyukse bile SL/TP bu yuzdeyi asamaz (guvenlik cap'i)
SCALP_MAX_SL_PCT=0.6
SCALP_MAX_TP_PCT=1.2
# Trailing (kademeli SL) baslatma esigi (%) - kisa vadede erken kilit
SCALP_TRAILING_TRIGGER_PCT=0.5

SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ─── Ücretsiz AI (Gemini) ───
# 5-beyinli LLM tartışması bu anahtarla çalışır. ÜCRETSİZ katman:
# https://aistudio.google.com/apikey  (Boş bırakılırsa sistem yalnızca kendi
# yerel ML ajanlarıyla çalışır ve yine otomatik işlem yapar.)
GEMINI_API_KEY=your_gemini_api_key
SYMBOL=BTC/USDT

# Gemini 5-Brain konsensüs ağırlığı (0 = devre dışı, 1 = tam ajan gibi sayılır)
GEMINI_WEIGHT=1.0
# Aç gözlülük / atak modu: false => sistem disiplinli, işlem agresifliğini otomatik artırmaz
AGGRESSIVE_MODE=false
# Günlük hedef (%). 0 = hedef yok (sadece risk yönetimi)
DAILY_GOAL_PCT=0

# Konsensüs gereken minimum ajan sayisi (scalping icin 2; tam uyusma zorunlu degil)
CONSENSUS_MIN=2
